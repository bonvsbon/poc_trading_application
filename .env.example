# ─────────────────────────────────────────────────────────────
# Alpaca configuration — คัดลอกไฟล์นี้เป็น .env แล้วเติมค่า
#   cp .env.example .env
# .env ถูก gitignore ไว้แล้ว จะไม่ถูก commit (ปลอดภัย)
# ─────────────────────────────────────────────────────────────

# ต้องมี: API key จาก Alpaca (แนะนำใช้ Paper Trading key ฟรี)
# ขอได้ที่ https://app.alpaca.markets  →  Home  →  "Generate New Keys"
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# ปล่อยว่าง/ไม่ตั้ง = ใช้ Paper (paper-api.alpaca.markets) — ปลอดภัยสำหรับทดสอบ
# ตั้งเป็น true เฉพาะเมื่อจะใช้บัญชีเงินจริง (api.alpaca.markets)
# ALPACA_LIVE=false

# ประตูนิรภัยชั้นที่สอง: ถึงจะมี key ที่ถูกต้อง การส่ง order จะถูกบล็อก
# จนกว่าจะตั้งค่านี้เป็น true (การดึงราคา/บัญชีไม่ต้องใช้ค่านี้)
# ALPACA_TRADING_ENABLED=false

# พอร์ตของเซิร์ฟเวอร์ (ดีฟอลต์ 3000)
# PORT=3000
